# ─── Servidor ──────────────────────────
HOST=127.0.0.1
PORT=8000
HEADLESS=false

# ─── Logging ───────────────────────────
LOG_LEVEL=INFO
LOG_FILE=web-agent.log
LOG_MAX_MB=10
LOG_BACKUP_COUNT=5

# ─── Edge Driver ───────────────────────
EDGE_DRIVER_PATH=

# ─── Janela ────────────────────────────
WINDOW_WIDTH=1280
WINDOW_HEIGHT=800
IMPLICIT_WAIT=2
PAGE_LOAD_TIMEOUT=30
SCRIPT_TIMEOUT=10

# ─── Execução ──────────────────────────
COMMAND_TIMEOUT=60
MAX_SESSION_VARIABLES=1000

# ─── Screenshots ───────────────────────
SCREENSHOT_QUALITY=70
SCREENSHOT_FORMAT=jpeg
SCREENSHOT_RETENTION_DAYS=7
SCREENSHOT_CLEANUP_INTERVAL_MINUTES=60

# ─── Auto-Heal ─────────────────────────
BROWSER_HEALTH_CHECK_INTERVAL=15
